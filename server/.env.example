# Leochat Server 环境变量配置模版
# 复制此文件到当前目录并重命名为 .env

# Flask 密钥，用于 session 安全，生产环境务必修改
# 建议通过以下命令生成：python3 -c "import os; print(os.urandom(24).hex())"
SECRET_KEY=leochat-secret-key-change-me

# Web 管理后台密码，不设置则启动时自动生成随机密码（见终端输出）
WEB_PASSWORD=admin123

# 是否开启调试模式 (true/false)
CHAT_DEBUG=false

# 服务端监听端口
CHAT_PORT=5000

# SQLite 数据库存储路径
DB_PATH=leochat.db
